{
 "Description": "IAM policies and group for Manguito CMS CDK workers",
 "Resources": {
  "WorkerPolicy462910EA": {
   "Type": "AWS::IAM::ManagedPolicy",
   "Properties": {
    "Description": "All permissions needed by a CDK worker: bootstrap + deploy",
    "ManagedPolicyName": "ManguitoCdkWorkerPolicy",
    "Path": "/",
    "PolicyDocument": {
     "Statement": [
      {
       "Action": "sts:AssumeRole",
       "Effect": "Allow",
       "Resource": "arn:aws:iam::*:role/cdk-*",
       "Sid": "AssumeBootstrapRoles"
      },
      {
       "Action": "cloudformation:*",
       "Effect": "Allow",
       "Resource": [
        "arn:aws:cloudformation:*:*:stack/*/*",
        "arn:aws:cloudformation:*:*:stack/CDKToolkit/*"
       ],
       "Sid": "CloudFormation"
      },
      {
       "Action": [
        "iam:AttachRolePolicy",
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:DeleteRolePolicy",
        "iam:DetachRolePolicy",
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:PutRolePolicy",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:UpdateAssumeRolePolicy",
        "iam:UpdateRole",
        "iam:UpdateRoleDescription"
       ],
       "Effect": "Allow",
       "Resource": "arn:aws:iam::*:role/cdk-*",
       "Sid": "IamRoles"
      },
      {
       "Action": [
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicyVersions"
       ],
       "Effect": "Allow",
       "Resource": "arn:aws:iam::*:policy/cdk-*",
       "Sid": "IamPolicies"
      },
      {
       "Action": "iam:PassRole",
       "Condition": {
        "StringEquals": {
         "iam:PassedToService": "cloudformation.amazonaws.com"
        }
       },
       "Effect": "Allow",
       "Resource": "arn:aws:iam::*:role/cdk-*",
       "Sid": "IamPassRoleToCfn"
      },
      {
       "Action": "s3:*",
       "Effect": "Allow",
       "Resource": [
        "arn:aws:s3:::cdk-hnb659fds-assets-*",
        "arn:aws:s3:::cdk-hnb659fds-assets-*/*"
       ],
       "Sid": "S3Assets"
      },
      {
       "Action": "ecr:GetAuthorizationToken",
       "Effect": "Allow",
       "Resource": "*",
       "Sid": "EcrAuth"
      },
      {
       "Action": "ecr:*",
       "Effect": "Allow",
       "Resource": "arn:aws:ecr:*:*:repository/cdk-hnb659fds-container-assets-*",
       "Sid": "EcrRepository"
      },
      {
       "Action": [
        "ssm:DeleteParameter",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:PutParameter"
       ],
       "Effect": "Allow",
       "Resource": "arn:aws:ssm:*:*:parameter/cdk-bootstrap/hnb659fds/version",
       "Sid": "SsmBootstrap"
      }
     ],
     "Version": "2012-10-17"
    }
   },
   "Metadata": {
    "aws:cdk:path": "IamWorkerStack/WorkerPolicy/Resource"
   }
  },
  "WorkersGroup3BD92287": {
   "Type": "AWS::IAM::Group",
   "Properties": {
    "GroupName": "manguito-cdk-workers",
    "ManagedPolicyArns": [
     {
      "Ref": "WorkerPolicy462910EA"
     }
    ]
   },
   "Metadata": {
    "aws:cdk:path": "IamWorkerStack/WorkersGroup/Resource"
   }
  },
  "CDKMetadata": {
   "Type": "AWS::CDK::Metadata",
   "Properties": {
    "Analytics": "v2:deflate64:H4sIAAAAAAAA/zPSMzI11zNQTCwv1k1OydbNyUzSqw4uSUzO1kksL47PTMzVq/ZNzEtMT00JyM/JTK7UcU7LQxVwL8ovLQAJgxm1IJZ/aUlBaUmtTl5+SqpeVrF+mZGRnpGRnqFiVnFmpm5RaV5JZm6qXhCEBgB1DWEngwAAAA=="
   },
   "Metadata": {
    "aws:cdk:path": "IamWorkerStack/CDKMetadata/Default"
   }
  }
 },
 "Outputs": {
  "WorkersGroupName": {
   "Description": "Add your CDK worker IAM user to this group",
   "Value": {
    "Ref": "WorkersGroup3BD92287"
   }
  },
  "WorkerPolicyArn": {
   "Description": "ManguitoCdkWorkerPolicy ARN",
   "Value": {
    "Ref": "WorkerPolicy462910EA"
   }
  }
 },
 "Parameters": {
  "BootstrapVersion": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Default": "/cdk-bootstrap/hnb659fds/version",
   "Description": "Version of the CDK Bootstrap resources in this environment, automatically retrieved from SSM Parameter Store. [cdk:skip]"
  }
 },
 "Rules": {
  "CheckBootstrapVersion": {
   "Assertions": [
    {
     "Assert": {
      "Fn::Not": [
       {
        "Fn::Contains": [
         [
          "1",
          "2",
          "3",
          "4",
          "5"
         ],
         {
          "Ref": "BootstrapVersion"
         }
        ]
       }
      ]
     },
     "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI."
    }
   ]
  }
 }
}