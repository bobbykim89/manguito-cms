# Copy to .env and fill in real values before running `cdk deploy`.
# These are passed straight through to the Lambda function / Fargate task as
# plain environment variables — fine for testing, but production deployments
# should graduate to Secrets Manager + a runtime-fetch pattern.

DB_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
AUTH_SECRET=replace-with-a-long-random-string

S3_BUCKET=
AWS_REGION=us-east-1

ALLOWED_ORIGIN=*
