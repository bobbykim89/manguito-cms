{
  "name": "manguito-cms-infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy:iam": "cdk deploy IamWorkerStack",
    "deploy:lambda": "pnpm --filter sandbox run build && cdk deploy LambdaStack",
    "deploy:fargate": "cdk deploy FargateStack",
    "destroy:lambda": "cdk destroy LambdaStack",
    "destroy:fargate": "cdk destroy FargateStack"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.1125.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3"
  }
}
