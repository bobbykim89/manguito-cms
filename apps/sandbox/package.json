{
  "name": "sandbox",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "manguito dev --env .env",
    "build": "manguito build --env .env",
    "build:vercel": "manguito build && rm -rf public && mkdir -p public/admin && cp -r dist/admin/. public/admin/",
    "start": "manguito start --env .env",
    "migrate": "manguito migrate --env .env",
    "validate": "manguito validate --env .env",
    "create:superuser": "manguito createsuperuser --env .env",
    "smoke": "dotenv -e ../../.env.test -- vitest run tests/smoke.test.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@bobbykim/manguito-cms-admin": "workspace:*",
    "@bobbykim/manguito-cms-api": "workspace:*",
    "@bobbykim/manguito-cms-cli": "workspace:*",
    "@bobbykim/manguito-cms-core": "workspace:*",
    "@bobbykim/manguito-cms-db": "workspace:*",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@bobbykim/manguito-cms-test-utils": "workspace:*",
    "@types/node": "^25.9.5",
    "dotenv-cli": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
