# Database (sandbox DB — run `pnpm db:sandbox:up` from repo root)
DB_URL=postgresql://postgres:postgres@localhost:5433/manguito_sandbox

# Storage (S3)
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Storage (Cloudinary) — alternative to S3
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Auth
AUTH_SECRET=

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=
